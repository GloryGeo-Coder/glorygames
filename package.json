{
  "name": "glorygames",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,rt \"npm run dev:web\" \"npm run dev:rt\"",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:rt": "npm run dev --prefix apps/realtime",
    "build": "npm run build --prefix apps/web",
    "lint": "npm run lint --prefix apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "prisma": "^6.19.2"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "jose": "^6.1.3",
    "next": "9.3.3",
    "redis": "^5.10.0",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.2.0",
    "wrangler": "3.107.3",
    "zod": "^4.3.6"
  }
}
