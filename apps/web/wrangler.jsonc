{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "glorygames",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-05-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "keep_vars": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true
    }
  }
}