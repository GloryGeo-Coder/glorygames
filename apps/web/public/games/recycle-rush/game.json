{
  "title": "Recycle Rush",
  "description": "Educational sorting game with polished HD graphics, animated gameplay, 3D-style waste item art, sound effects, background music, and eight difficulty-progressive levels.",
  "tags": [
    "education",
    "environment",
    "recycling",
    "climate",
    "sustainability",
    "mobile",
    "touch",
    "arcade"
  ],
  "controls": [
    {
      "key": "Swipe Left / Right",
      "action": "Change the active recycling bin"
    },
    {
      "key": "Tap bin",
      "action": "Jump directly to a visible bin"
    },
    {
      "key": "Tap orange hazard",
      "action": "Remove mixed-waste contamination"
    },
    {
      "key": "Pause / Restart / Sound",
      "action": "Control the run"
    }
